{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "mind-neural",
  "compatibility_date": "2026-03-17",
  "pages_build_output_dir": "./dist",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  // KV namespace for effortless cross-device sync (MIND_SYNC)
  // Stores sync:{code}:snapshot|identity|timeline|ping — 30-day TTL auto-renews
  "kv_namespaces": [
    {
      "binding": "MIND_SYNC",
      "id": "9946a32d1b084948867f1d42446c5464"
    }
  ]
}